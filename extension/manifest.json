{
  "manifest_version": 3,
  "name": "Fake Content Detection Assistant",
  "version": "1.0.0",
  "description": "Right-click any image to analyze possible AI generation or deepfake manipulation.",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Fake Content Detection Assistant",
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "icons": {
    "128": "icon128.png"
  }
}
